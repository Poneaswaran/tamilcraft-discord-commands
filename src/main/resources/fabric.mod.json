{
	"schemaVersion": 1,
	"id": "tamilcraft-discord-commands",
	"version": "${version}",
	"name": "tamilcraft-discord-commands",
	"description": "This is an example description! Tell everyone what your mod is about!",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/tamilcraft-discord-commands/icon.png",
	"environment": "*",
	"entrypoints": {
		"preLaunch": [
			{
				"value": "tamilcraft.discordcommands.DiscordCommandsMod",
				"adapter": "kotlin"
			}
		],
		"main": [
			{
				"value": "tamilcraft.discordcommands.DiscordCommandsMod",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"tamilcraft-discord-commands.mixins.json",
		{
			"config": "tamilcraft-discord-commands.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.5",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}